Package: NSTempRFA
Title: Adapts the Regional Frequency Analysis to Air Temperature
Version: 0.1.0
Authors@R: c(
    person("Gabriel Constantino", "Blain", , "gabriel.blain@sp.gov.br", role = c("aut", "cre"),
